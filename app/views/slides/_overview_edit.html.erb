<div class="overview-edit hidden"
     data-overview-edit-target="root"
     data-action="click->overview-edit#backdropClick">
  <div class="overview-edit__panel" data-action="click->overview-edit#stopPropagation">
    <header class="overview-edit__header">
      <span>Overview</span>
      <span class="overview-edit__hint">Drag tiles to reorder · click to edit · × to delete</span>
      <button type="button" data-action="overview-edit#close" class="overview-edit__close">×</button>
    </header>

    <div class="overview-edit__grid">
      <% presentation.slides.each do |s| %>
        <div class="overview-edit__tile theme-<%= presentation.theme %> mode-<%= presentation.mode %>"
             draggable="true"
             data-overview-edit-target="tile"
             data-position="<%= s.position %>"
             data-action="dragstart->overview-edit#dragStart dragover->overview-edit#dragOver drop->overview-edit#drop dragend->overview-edit#dragEnd click->overview-edit#openSlide">
          <button type="button"
                  class="overview-edit__delete"
                  title="Delete slide"
                  data-action="click->overview-edit#deleteSlide"
                  data-position="<%= s.position %>">×</button>
          <div class="overview-edit__thumb-frame">
            <div class="overview-edit__thumb slide<%= ' slide--center' if s.centered? %>">
              <div class="slide-content">
                <%== s.html %>
              </div>
            </div>
          </div>
          <div class="overview-edit__caption">
            <span class="overview-edit__num"><%= s.position %></span>
            <span class="overview-edit__title"><%= s.title %></span>
          </div>
        </div>
      <% end %>

      <button type="button"
              class="overview-edit__tile overview-edit__add"
              data-action="overview-edit#addSlide">
        <span>+ new slide</span>
      </button>
    </div>
  </div>
</div>
