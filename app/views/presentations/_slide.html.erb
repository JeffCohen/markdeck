<section
  class="slide<%= ' slide--center' if slide.centered? %>"
  data-deck-target="slide"
  data-slide-index="<%= slide.index %>"
  aria-hidden="true"
>
  <div class="slide-content">
    <%== slide.html %>
  </div>

  <% if slide.notes? %>
    <aside class="speaker-peek speaker-peek--notes" aria-hidden="true">
      <div class="speaker-peek__label">
        Notes &middot; slide <%= slide.number %>
      </div>
      <div class="speaker-peek__body slide-content">
        <%== slide.notes_html %>
      </div>
    </aside>
  <% end %>

  <% if (nxt = presentation.slides[slide.index + 1]) %>
    <aside class="speaker-peek speaker-peek--preview" aria-hidden="true">
      <div class="speaker-peek__label">
        Next &middot; <%= nxt.number %> &middot; <%= nxt.title %>
      </div>
      <div class="thumb-preview">
        <div class="thumb-content slide-content">
          <%== nxt.html %>
        </div>
      </div>
    </aside>
  <% end %>
</section>
