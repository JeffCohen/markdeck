<% content_for :title, "#{@presentation.title} · Markdeck" %>

<div class="overview-page"
     style="background: var(--app-bg); color: var(--app-fg); font-family: var(--md-font-body), system-ui, sans-serif; min-height: 100vh;"
     data-controller="overview-edit palette settings"
     data-overview-edit-slug-value="<%= @presentation.slug %>"
     data-overview-edit-create-url-value="<%= presentation_slides_path(@presentation) %>"
     data-overview-edit-reorder-url-value="<%= presentation_slide_order_path(@presentation) %>"
     data-palette-slides-value="<%= slides_palette_json(@presentation, target: :present).to_json %>"
     data-settings-update-url-value="<%= presentation_settings_path(@presentation) %>"
     data-settings-default-colors-value="<%= { dark: Presentation::DEFAULT_COLORS_DARK, light: Presentation::DEFAULT_COLORS_LIGHT }.to_json %>"
     data-settings-body-size-scales-value="<%= Presentation::BODY_SIZE_SCALES.to_json %>">

  <header class="overview-page__top">
    <a href="<%= presentations_path %>" class="overview-page__crumb" data-turbo="false">← all decks</a>
    <h1 class="overview-page__title">
      <%= @presentation.title %>
      <span class="overview-page__subtitle"><%= pluralize(@presentation.slides.size, "slide") %></span>
    </h1>
    <div class="overview-page__actions">
      <button type="button" class="editor__btn" data-action="settings#open">
        Settings
      </button>
      <a href="<%= presentation_slide_path(@presentation, n: 1) %>"
         class="editor__btn editor__btn--primary"
         data-turbo="false">
        Present →
      </a>
    </div>
  </header>

  <main class="overview-page__grid" data-action="keydown->overview-edit#handleKey">
    <% @presentation.slides.each do |slide| %>
      <div class="overview-edit__tile theme-<%= @presentation.theme %> mode-<%= @presentation.mode %>"
           draggable="true"
           tabindex="0"
           data-overview-edit-target="tile"
           data-position="<%= slide.position %>"
           data-action="dragstart->overview-edit#dragStart dragover->overview-edit#dragOver drop->overview-edit#drop dragend->overview-edit#dragEnd click->overview-edit#presentSlide">
        <button type="button"
                class="overview-edit__delete"
                title="Delete slide"
                data-action="click->overview-edit#deleteSlide"
                data-position="<%= slide.position %>">×</button>
        <a class="overview-edit__edit-pill"
           href="<%= edit_presentation_slide_path(@presentation, n: slide.position) %>"
           data-turbo="false"
           data-action="click->overview-edit#stopPropagation"
           title="Edit slide">edit</a>
        <div class="overview-edit__thumb-frame">
          <div class="overview-edit__thumb slide<%= ' slide--center' if slide.centered? %>">
            <div class="slide-content">
              <%== slide.html %>
            </div>
          </div>
        </div>
        <div class="overview-edit__caption">
          <span class="overview-edit__num"><%= slide.position %></span>
          <span class="overview-edit__title"><%= slide.title %></span>
        </div>
      </div>
    <% end %>

    <button type="button"
            class="overview-edit__tile overview-edit__add"
            tabindex="0"
            data-overview-edit-target="add"
            data-action="overview-edit#addSlide">
      <span>+ new slide</span>
    </button>
  </main>

  <footer class="overview-page__footer">
    <span>Click a slide to present · drag to reorder · "edit" pill to edit · <kbd>⌘K</kbd> to jump</span>
  </footer>

  <%= render "slides/palette" %>

  <div class="settings hidden" data-settings-target="root" data-action="click->settings#backdropClick">
    <div class="settings__panel" data-action="click->settings#stopPropagation">
      <h3 class="settings__title">Deck settings</h3>

      <div class="settings__preview">
        <div class="thumb-preview" data-settings-target="previewFrame">
          <div class="thumb-content slide-content">
            <h2>Sample heading</h2>
            <p>
              Body copy in <span class="accent">accent</span>, <span class="muted">muted</span>,
              <span class="fg">fg</span>, and <span class="highlight">highlight</span>,
              plus a <span class="settings__swatch"></span> bg swatch.
            </p>
            <pre><code>const mono = "sample";</code></pre>
          </div>
        </div>
      </div>

      <div class="settings__field">
        <span class="settings__label">Theme</span>
        <div class="settings__radios">
          <% Presentation::THEMES.each do |theme| %>
            <label class="settings__radio">
              <input type="radio" name="theme" value="<%= theme %>" data-settings-target="theme"
                     data-action="change->settings#syncPreview"
                     <%= "checked" if theme == @presentation.theme %>>
              <span><%= theme.titleize %></span>
            </label>
          <% end %>
        </div>
      </div>

      <div class="settings__field">
        <span class="settings__label">Mode</span>
        <div class="settings__radios">
          <% Presentation::MODES.each do |mode| %>
            <label class="settings__radio">
              <input type="radio" name="mode" value="<%= mode %>" data-settings-target="mode"
                     data-action="change->settings#modeChanged"
                     <%= "checked" if mode == @presentation.mode %>>
              <span><%= mode.titleize %></span>
            </label>
          <% end %>
        </div>
      </div>

      <div class="settings__field">
        <span class="settings__label">Colors</span>
        <div class="settings__colors">
          <% %w[bg fg accent muted highlight].each do |key| %>
            <label class="settings__color">
              <input type="color" data-settings-target="color" data-key="<%= key %>"
                     data-action="input->settings#syncPreview"
                     value="<%= @presentation.colors[key] %>">
              <span><%= key %></span>
            </label>
          <% end %>
        </div>
      </div>

      <div class="settings__field">
        <span class="settings__label">Fonts</span>
        <% %w[heading body mono].each do |key| %>
          <label class="settings__font">
            <span class="settings__font-label"><%= key %></span>
            <input type="text" data-settings-target="font" data-key="<%= key %>"
                   data-action="input->settings#syncPreview"
                   value="<%= @presentation.fonts[key] %>">
          </label>
        <% end %>
      </div>

      <div class="settings__field">
        <span class="settings__label">Body size</span>
        <div class="settings__radios">
          <% Presentation::BODY_SIZES.each do |size| %>
            <label class="settings__radio">
              <input type="radio" name="body_size" value="<%= size %>" data-settings-target="bodySize"
                     data-action="change->settings#syncPreview"
                     <%= "checked" if size == @presentation.body_size %>>
              <span><%= size.titleize %></span>
            </label>
          <% end %>
        </div>
      </div>

      <div class="settings__actions">
        <span class="settings__status" data-settings-target="status"></span>
        <button type="button" class="editor__btn" data-action="settings#close">Cancel</button>
        <button type="button" class="editor__btn editor__btn--primary" data-action="settings#save">Save</button>
      </div>
    </div>
  </div>
</div>
