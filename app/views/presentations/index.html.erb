<% content_for :title, "Markdeck" %>

<header class="border-b border-neutral-800">
  <div class="max-w-5xl mx-auto px-6 py-10 flex items-baseline justify-between">
    <h1 class="text-2xl font-semibold tracking-tight flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 68.43 122.88"
           fill="currentColor" class="h-7 w-auto text-neutral-100" aria-hidden="true">
        <path fill-rule="evenodd" d="M49.13,41.83H17.46c-1,3.33-2.13,6.93-3.35,10.66-3.54,10.9-7.49,23-7.63,33.07-.16,11.34,5,20.23,22.58,21.58h4.49a1.31,1.31,0,0,1-.48-1l-.43-1.29A33,33,0,0,1,27.2,100l-.95-1.15C13.7,82.71,34,65.1,30.24,57.18h0c13.65,11.71,21.59,28,11.6,41.56L41,99.87a33.51,33.51,0,0,1-5,4.84v1.41a1.32,1.32,0,0,1-.49,1h5.59c14.72-1.35,19.71-8.65,20.08-18.24.41-10.58-4.27-24.15-8.4-36.17-1.31-3.82-2.57-7.48-3.62-10.9ZM33.83,0a10.68,10.68,0,0,1,7.55,18.24h0a10.41,10.41,0,0,1-1.29,1.1v.91H52.16a2.23,2.23,0,0,1,2.22,2.22v5.66h3a2.23,2.23,0,0,1,2.22,2.22v6.18a2.24,2.24,0,0,1-2.22,2.22H54.63c1.07,3.63,2.48,7.71,3.95,12,4.3,12.51,9.16,26.63,8.71,38.39-.29,7.63-2.66,14.17-8.46,18.55.41.45.68,1.12,1.09,1.69l2,2.77c4,2,6.52,4.77,6.52,8.53a2.24,2.24,0,0,1-2.22,2.22h-64A2.23,2.23,0,0,1,0,120.66c0-2,1.59-3.79,4.27-5.4l4.24-5.9a13.2,13.2,0,0,1,1.22-1.83c-7.1-5-9.51-12.93-9.39-22,.15-11,4.25-23.6,7.92-34.9,1.36-4.19,2.67-8.19,3.67-11.84H10.36a2.23,2.23,0,0,1-2.21-2.22V30.35a2.22,2.22,0,0,1,2.21-2.22h3V22.47a2.23,2.23,0,0,1,2.22-2.22H27.61v-.87a9.73,9.73,0,0,1-1.34-1.14l-.13-.14A10.68,10.68,0,0,1,33.83,0Zm4.29,6.4a6.07,6.07,0,0,0-9.62,7.2H39.15a6.09,6.09,0,0,0-1-7.2ZM32,73.63C39.65,81,44.11,91.29,38.5,99.81l-.5.72-2.23,3-2.44.07a18.64,18.64,0,0,1-3-3l-.54-.72c-7-10.17,4.35-21.26,2.24-26.25Z"/>
      </svg>
      <span class="text-neutral-100">Lantern</span>
      <span class="text-neutral-500"> &middot; presentations</span>
    </h1>
    <p class="text-sm text-neutral-500">
      <%= pluralize(@presentations.size, "deck") %>
    </p>
  </div>
</header>

<main class="max-w-5xl mx-auto px-6 py-12">
  <% if @presentations.empty? %>
    <div class="border border-dashed border-neutral-800 rounded-lg p-12 text-center">
      <p class="text-neutral-400 mb-2">No presentations yet.</p>
      <p class="text-sm text-neutral-600">
        Create a folder under <code class="text-neutral-300">presentations/</code> with a
        <code class="text-neutral-300">config.yml</code> and a <code class="text-neutral-300">slides/</code> directory.
      </p>
    </div>
  <% else %>
    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5" data-controller="index">
      <% @presentations.each do |deck| %>
        <li>
          <%= link_to presentation_path(deck), data: { index_target: "link", turbo: false }, class: "block group rounded-lg border border-neutral-800 hover:border-neutral-600 focus-visible:border-neutral-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-neutral-600 transition-colors p-6 h-full" do %>
            <div class="flex items-center gap-2 mb-3">
              <span class="inline-flex items-center text-[10px] uppercase tracking-wider text-neutral-500 px-2 py-0.5 rounded border border-neutral-800">
                <%= deck.theme %>
              </span>
              <span class="inline-flex items-center text-[10px] uppercase tracking-wider text-neutral-500 px-2 py-0.5 rounded border border-neutral-800">
                <%= deck.mode %>
              </span>
              <span class="text-[10px] uppercase tracking-wider text-neutral-600">
                <%= pluralize(deck.slides.size, "slide") %>
              </span>
            </div>
            <h2 class="text-lg font-medium text-neutral-100 group-hover:text-white">
              <%= deck.title %>
            </h2>
            <p class="text-sm text-neutral-500 mt-1 truncate">
              <%= deck.slug %>
            </p>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% end %>
</main>
